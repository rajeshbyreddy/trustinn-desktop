{
  "name": "trustinn-desktop",
  "version": "2.0.0",
  "description": "Trustinn Desktop - Unified Tool Runner",
  "author": "Trustinn",
  "main": "src/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "electron": "electron .",
    "electron-dev": "NODE_ENV=development vite > /tmp/vite.log 2>&1 & sleep 3 && electron .",
    "start": "npm run electron-dev",
    "docker:build": "docker build -f docker/Dockerfile -t pasup/trustinn-tools:2.0.0 /home/rajesh",
    "docker:push": "docker push pasup/trustinn-tools:2.0.0",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "release:tag": "git tag v2.0.0 && git push origin v2.0.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.trustinn.desktop",
    "productName": "Trustinn",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "installer/windows-prereq-setup.ps1",
        "to": "windows-prereq-setup.ps1"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer/installer.nsh"
    }
  }
}
